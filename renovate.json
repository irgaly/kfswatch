{
  "extends": [
    "config:recommended",
    "schedule:quarterly"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "enabled": false
    },
    {
      "groupName": "Kotlin",
      "matchPackageNames": [
        "org.jetbrains.kotlin:*",
        "org.jetbrains.kotlin.*"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "enabled": true
    },
    {
      "groupName": "Kotest",
      "matchPackageNames": [
        "io.kotest.multiplatform",
        "io.kotest:kotest-*"
      ]
    }
  ]
}
